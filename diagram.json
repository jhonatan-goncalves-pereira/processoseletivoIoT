{
  "version": 1,
  "author": "Jhonatan Gonçalves Pereira",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-led", "id": "led_verde",    "top": -100, "left": 200, "attrs": { "color": "green"  } },
    { "type": "wokwi-led", "id": "led_amarelo",  "top":    0, "left": 200, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led_vermelho", "top":  100, "left": 200, "attrs": { "color": "red"    } },
    { "type": "wokwi-resistor", "id": "r1", "top": -100, "left": 320, "attrs": { "resistance": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top":    0, "left": 320, "attrs": { "resistance": "220" } },
    { "type": "wokwi-resistor", "id": "r3", "top":  100, "left": 320, "attrs": { "resistance": "220" } }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],
    [ "esp:26", "led_verde:A",    "green",  [] ],
    [ "led_verde:C",    "r1:1", "green",  [] ],
    [ "r1:2", "esp:GND.1", "black", [] ],
    [ "esp:25", "led_amarelo:A",  "yellow", [] ],
    [ "led_amarelo:C",  "r2:1", "yellow", [] ],
    [ "r2:2", "esp:GND.1", "black", [] ],
    [ "esp:33", "led_vermelho:A", "red",    [] ],
    [ "led_vermelho:C", "r3:1", "red",    [] ],
    [ "r3:2", "esp:GND.1", "black", [] ]
  ]
}